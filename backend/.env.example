# Copie este arquivo para .env (produção) ou .env.local (dev local)
# NUNCA comita .env ou .env.local no repositório — estão no .gitignore

# [SEC-A02] Gere uma chave segura: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here-CHANGE-ME

# [SEC-A05] DEBUG=False em produção — nunca expor traceback ao cliente
DEBUG=False

# [SEC-A05] Liste os hosts permitidos explicitamente (sem wildcard em produção)
ALLOWED_HOSTS=localhost,127.0.0.1

# [SEC-A07] Taxa de throttling (opcional — sobrescreve o padrão do settings.py)
# THROTTLE_RATE_ANON=20/minute
# THROTTLE_RATE_USER=200/minute

# Database
DB_NAME=financial_db
DB_USERNAME=postgres
DB_PASSWORD=CHANGE-ME-USE-STRONG-PASSWORD
DB_HOST=localhost
DB_PORT=5432
# [SEC-A02] Use 'require' em produção para encriptar a conexão com o banco
DB_SSL_MODE=require

# Keycloak / Identity Manager
KEYCLOAK_SERVER_URL=https://your-keycloak-host
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=financial-backend
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_ALGORITHMS=RS256
# [SEC-A02] Sempre True em produção — False SOMENTE para dev local sem TLS
KEYCLOAK_VERIFY_SSL=True
# [SEC-A07] Sempre True — desabilite apenas se o Keycloak não emite a claim 'aud'
KEYCLOAK_VERIFY_AUDIENCE=True

# [SEC-A01/A05] Origens CORS permitidas (lista separada por vírgula, sem wildcard)
# Exemplo: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:4200
