{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": ["node"]
  },
  "files": ["src/main.ts", "src/main.server.ts", "src/server.ts"],
  "include": [
    "src/**/*.ts", // <--- Adicione isso: inclui todos os arquivos TS
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/test.ts", // Exclua arquivos de teste se houver
    "src/**/*.spec.ts" // Exclua os specs (eles devem ficar no tsconfig.spec.json)
  ]
}
